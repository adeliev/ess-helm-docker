# Coturn TURN Server Configuration for Element
# WebRTC TURN/STUN server for voice and video calls
# Copy this file to turnserver.conf and replace placeholder values

# Listening ports
listening-port=3479
tls-listening-port=5349

# Listening IPs - use 0.0.0.0 for all interfaces
listening-ip=0.0.0.0

# External IP (replace with your actual external IP)
# This should be your server's public IP address
# external-ip=YOUR_PUBLIC_IP

# Relay IPs
relay-ip=0.0.0.0

# Realm for authentication
realm=turn.yourdomain.com
server-name=turn.yourdomain.com

# Shared secret for authentication with Synapse
# Generate with: openssl rand -base64 64
use-auth-secret
static-auth-secret=YOUR_TURN_SHARED_SECRET_HERE

# Total quota
total-quota=100

# Max TURN sessions per user
user-quota=10
max-bps=1000000

# Certificate paths (optional for TLS)
# cert=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# pkey=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Disable TLS for now (can enable later)
no-tls
no-dtls

# Logging
verbose
# Log to stdout for Docker
syslog

# Additional security
fingerprint
lt-cred-mech

# Disable UDP relay endpoints
no-udp-relay

# Enable TCP relay
tcp-relay-port=3479

# Compatibility
no-multicast-peers
no-cli
