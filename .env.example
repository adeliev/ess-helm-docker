# Element Server Suite - Environment Variables
# Copy this file to .env and replace placeholder values with secure passwords

# ============================================
# PostgreSQL Database
# ============================================
# Strong password for PostgreSQL database
# Generate with: openssl rand -base64 32
# Example: EvKEnhTXPNtUhv2M/ZPl6m+SPaGOWcNMa4mfE0cNVgI=
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE

# ============================================
# Synapse Homeserver
# ============================================
# Matrix server name (your domain)
# This should match your actual domain name
SYNAPSE_SERVER_NAME=matrix.yourdomain.com

# Report anonymous usage statistics to matrix.org
# Set to "yes" to help Matrix development, or "no" for privacy
SYNAPSE_REPORT_STATS=no

# ============================================
# Coturn TURN Server
# ============================================
# Shared secret for TURN authentication
# IMPORTANT: Must match the value in:
#   - config/coturn/turnserver.conf (static-auth-secret)
#   - data/synapse/homeserver.yaml (turn_shared_secret)
# Generate with: openssl rand -base64 64
# Example: RieehFfoVtTcUnxvAMEbW9KotTerGz+9mYju4VgIyQawgxfdGKiHWQVSoytOCUchhh2Us+ONvjJyRlb2i2uGVw==
TURN_SHARED_SECRET=YOUR_TURN_SHARED_SECRET_HERE

# ============================================
# Setup Instructions
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Generate secure passwords using the commands above
# 3. Update .env with your actual values
# 4. Update config/coturn/turnserver.conf with the same TURN secret
# 5. After first Synapse start, update data/synapse/homeserver.yaml:
#    - Set turn_shared_secret to match TURN_SHARED_SECRET
#    - Update database password to match POSTGRES_PASSWORD
# 6. Restart services: docker compose restart
